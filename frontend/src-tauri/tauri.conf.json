{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "TradingResearchPlatform",
    "version": "0.1.0"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "identifier": "com.trading.research.platform",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Trading Research Platform",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
